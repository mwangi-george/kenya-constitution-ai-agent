APP_NAME='Kenya Constitution Chatbot'
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
API_ROOT_PATH=

OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RETRIEVAL_TOP_K=5
CHUNK_SIZE=1800
CHUNK_OVERLAP=250

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=constitution_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
